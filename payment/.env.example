# ============================================
# Payment API Environment Variables
# 결제 API 환경 변수 설정
# ============================================

# --------------------------------------------
# Server Configuration
# 서버 설정
# --------------------------------------------
PORT=3004
NODE_ENV=development
# Options: development, production, test

# --------------------------------------------
# CORS Configuration
# CORS 설정
# --------------------------------------------
CORS_ORIGIN=*
# For production, set specific origins:
# CORS_ORIGIN=https://yourdomain.com,https://api.yourdomain.com
# Multiple origins: separate with commas

# --------------------------------------------
# HTTPS Configuration
# HTTPS 설정
# --------------------------------------------
ENFORCE_HTTPS=false
# For production, set to true: ENFORCE_HTTPS=true
# This enforces HTTPS for all API endpoints

# --------------------------------------------
# Database Configuration (MySQL)
# 데이터베이스 설정 (MySQL)
# Requirements: 11.3, 11.4
# --------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_change_me
DB_NAME=ecommerce
DB_PORT=3306
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Database initialization (for development/testing only)
# 데이터베이스 초기화 (개발/테스트 전용)
AUTO_INIT_DB=true
# Set to false in production

# --------------------------------------------
# JWT Configuration
# JWT 설정
# Requirements: 11.5
# --------------------------------------------
JWT_SECRET=your-jwt-secret-minimum-32-characters-long-change-me
# IMPORTANT: Must be at least 32 characters long
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRATION=24h
# Options: 1h, 24h, 7d, etc.

# --------------------------------------------
# Encryption Configuration (AES-256)
# 암호화 설정 (AES-256)
# Requirements: 8.6, 11.2, 11.5
# --------------------------------------------
ENCRYPTION_KEY=your-32-byte-encryption-key-change-me-in-production
# IMPORTANT: Must be exactly 32 bytes (64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

ENCRYPTION_IV=your-16-byte-iv-change-me
# IMPORTANT: Must be exactly 16 bytes (32 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

# --------------------------------------------
# Logging Configuration
# 로깅 설정
# Requirements: 10.1, 10.2, 10.3, 10.4, 10.5, 10.6
# --------------------------------------------
LOG_LEVEL=info
# Options: error, warn, info, debug
LOG_FILE_PATH=/var/log/payments-api/payments.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=30

# --------------------------------------------
# Security Configuration
# 보안 설정
# Requirements: 11.1
# --------------------------------------------
# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
# Maximum requests per window

# Request Size Limit
MAX_REQUEST_SIZE=1048576
# 1MB in bytes

# --------------------------------------------
# Payment Gateway Configuration (Optional)
# 결제 게이트웨이 설정 (선택사항)
# --------------------------------------------
# PAYMENT_GATEWAY_URL=https://api.payment-gateway.com
# PAYMENT_GATEWAY_API_KEY=your-gateway-api-key
# PAYMENT_GATEWAY_SECRET=your-gateway-secret
# PAYMENT_GATEWAY_TIMEOUT=30000

# --------------------------------------------
# AWS Configuration (Optional - for production)
# AWS 설정 (선택사항 - 프로덕션용)
# --------------------------------------------
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# --------------------------------------------
# Monitoring & Observability (Optional)
# 모니터링 및 관찰성 (선택사항)
# --------------------------------------------
# ENABLE_METRICS=true
# METRICS_PORT=9090
# ENABLE_TRACING=false
# TRACING_ENDPOINT=http://jaeger:14268/api/traces

# ============================================
# IMPORTANT SECURITY NOTES
# 중요 보안 사항
# ============================================
# 1. NEVER commit this file with real credentials
#    실제 자격 증명으로 이 파일을 커밋하지 마세요
# 2. Generate strong random values for all secrets
#    모든 시크릿에 대해 강력한 랜덤 값을 생성하세요
# 3. Use different values for each environment
#    각 환경마다 다른 값을 사용하세요
# 4. Store production secrets in secure vaults (AWS Secrets Manager, etc.)
#    프로덕션 시크릿은 보안 볼트에 저장하세요 (AWS Secrets Manager 등)
# 5. Rotate secrets regularly
#    시크릿을 정기적으로 교체하세요
# ============================================
